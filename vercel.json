{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "cd frontend && npm install --workspaces=false",
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "routes": [
    { "handle": "filesystem" },
    { "src": "/akun", "dest": "/index.html" },
    { "src": "/pesanan", "dest": "/index.html" },
    { "src": "/promo", "dest": "/index.html" },
    { "src": "/lokasi", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
